[gd_resource type="VisualShader" format=3 uid="uid://uy8q5gloc3wg"]

[sub_resource type="VisualShaderNodeTexture2DParameter" id="VisualShaderNodeTexture2DParameter_w7huw"]
parameter_name = "Noise"

[sub_resource type="VisualShaderNodeVec2Parameter" id="VisualShaderNodeVec2Parameter_w7huw"]
parameter_name = "Offset"

[sub_resource type="VisualShaderNodeExpression" id="VisualShaderNodeExpression_daige"]
size = Vector2(1080, 580)
expression = "OUTPUT_VERTEX = Vertex;
vec2 sample_uv = Vertex.xz + Offset;
OUTPUT_VERTEX.y = ((texture(Noise, sample_uv).x + 1.0) / 2.0) * Height 
	- Height / 2.0; // push down the mesh the same amount it went down

float size = 1.0 / float(textureSize(Noise, 0).x);
float t = texture(NoiseNormal, sample_uv + vec2(size * vec2(0.0, -1.0))).r * Height;
float r = texture(NoiseNormal, sample_uv + vec2(size * vec2(1.0, 0.0))).r * Height;
float l = texture(NoiseNormal, sample_uv + vec2(size * vec2(-1.0, 0.0))).r * Height;
float b = texture(NoiseNormal, sample_uv + vec2(size * vec2(0.0, 1.0))).r * Height;

OUTPUT_NORMAL = -normalize(vec3(2.0 * (r - l), 2.0 * (b - t), -4.0));

/*vec2 size = 1.0 / vec2(textureSize(Noise, 0));
float left = texture(Noise, sample_uv + vec2(size * vec2(-1.0, 0.0))).r * Height;
float right = texture(Noise, sample_uv + vec2(size * vec2(1.0, 0.0))).r * Height;
float up = texture(Noise, sample_uv + vec2(size * vec2(0.0, -1.0))).r * Height;
float down = texture(Noise, sample_uv + vec2(size * vec2(0.0, 1.0))).r * Height;

OUTPUT_NORMAL = normalize(vec3(left - right, 2.0 * size.x, up - down));*/"

